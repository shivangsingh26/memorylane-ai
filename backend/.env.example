# Copy this file to .env and fill in your values

# OpenAI API key (required)
OPENAI_API_KEY=sk-your-key-here

# GPT model to use (gpt-4.1 is latest as of 2025)
MODEL_NAME=gpt-5.1

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# User names (match exactly how they appear after normalization)
USER1_NAME=Shivang
USER2_NAME=Krishna

# Chunk size for RAG (messages per chunk)
CHUNK_SIZE=7

# How many chunks to retrieve per query
RAG_TOP_K=5
